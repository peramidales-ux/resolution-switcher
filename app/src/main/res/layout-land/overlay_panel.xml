<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlayRoot"
    android:layout_width="400dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/overlay_bg"
    android:padding="0dp"
    android:elevation="8dp">

    <!-- Header (draggable) -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/overlay_header"
        android:paddingStart="12dp"
        android:paddingEnd="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/panel_title"
            android:textColor="@color/on_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnCollapse"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_collapse"
            android:contentDescription="@string/collapse"
            android:scaleType="centerInside" />
    </LinearLayout>

    <!-- Content: horizontal layout for landscape -->
    <LinearLayout
        android:id="@+id/content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp">

        <!-- Left: sliders -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNativeRes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/on_surface_variant"
                android:textSize="10sp"
                android:layout_marginBottom="4dp" />

            <!-- Width -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:text="@string/width_label"
                    android:textColor="@color/on_surface"
                    android:textSize="11sp" />

                <SeekBar
                    android:id="@+id/seekWidth"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="100"
                    android:progressTint="@color/slider_thumb"
                    android:thumbTint="@color/slider_thumb" />

                <EditText
                    android:id="@+id/etWidth"
                    android:layout_width="60dp"
                    android:layout_height="30dp"
                    android:layout_marginStart="4dp"
                    android:background="@color/surface_variant"
                    android:textColor="@color/on_surface"
                    android:textSize="12sp"
                    android:inputType="number"
                    android:gravity="center"
                    android:padding="2dp" />
            </LinearLayout>

            <!-- Height -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <TextView
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:text="@string/height_label"
                    android:textColor="@color/on_surface"
                    android:textSize="11sp" />

                <SeekBar
                    android:id="@+id/seekHeight"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="100"
                    android:progressTint="@color/slider_thumb"
                    android:thumbTint="@color/slider_thumb" />

                <EditText
                    android:id="@+id/etHeight"
                    android:layout_width="60dp"
                    android:layout_height="30dp"
                    android:layout_marginStart="4dp"
                    android:background="@color/surface_variant"
                    android:textColor="@color/on_surface"
                    android:textSize="12sp"
                    android:inputType="number"
                    android:gravity="center"
                    android:padding="2dp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnReset"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:text="@string/reset_button"
                android:textSize="11sp"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- Right: presets -->
        <LinearLayout
            android:layout_width="140dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/presets_title"
                android:textColor="@color/on_surface"
                android:textSize="11sp"
                android:textStyle="bold" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupPresets"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </ScrollView>

            <Button
                android:id="@+id/btnSavePreset"
                android:layout_width="match_parent"
                android:layout_height="28dp"
                android:text="@string/save_preset"
                android:textSize="10sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

    </LinearLayout>
</LinearLayout>
