<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <!-- Logo -->
        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginTop="24dp"
            android:src="@drawable/ic_tiger_logo"
            android:scaleType="centerCrop" />

        <!-- App name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LAENFAER"
            android:textColor="@color/on_surface"
            android:fontFamily="sans-serif-black"
            android:textSize="28sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginTop="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RESOLUTION SWITCHER"
            android:textColor="@color/primary"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/tvVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/on_surface_variant"
            android:textSize="11sp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="28dp" />

        <!-- Overlay permission card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="18dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:layout_width="4dp"
                    android:layout_height="40dp"
                    android:background="@color/accent" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ОВЕРЛЕЙ"
                        android:textColor="@color/on_surface"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Разрешение поверх приложений"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/overlayStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <Button
                android:id="@+id/btnGrantOverlay"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="ПРЕДОСТАВИТЬ РАЗРЕШЕНИЕ"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:layout_marginTop="12dp"
                android:background="@drawable/btn_accent_bg" />
        </LinearLayout>

        <!-- Root card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="18dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:layout_width="4dp"
                    android:layout_height="40dp"
                    android:background="@color/status_green" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ROOT"
                        android:textColor="@color/on_surface"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/rootStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/btnUseRoot"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="ИСПОЛЬЗОВАТЬ ROOT"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:layout_marginTop="12dp"
                android:background="@drawable/btn_orange_bg" />
        </LinearLayout>

        <!-- Shizuku card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="18dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:layout_width="4dp"
                    android:layout_height="40dp"
                    android:background="@color/primary" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SHIZUKU"
                        android:textColor="@color/on_surface"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/shizukuStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <Button
                    android:id="@+id/btnSetupShizuku"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="НАСТРОИТЬ"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:background="@drawable/btn_outline_bg" />

                <Button
                    android:id="@+id/btnUseShizuku"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="ВЫБРАТЬ"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:background="@drawable/btn_orange_bg" />
            </LinearLayout>
        </LinearLayout>

        <!-- UsageStats permission card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="18dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:layout_width="4dp"
                    android:layout_height="40dp"
                    android:background="@color/accent" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ОТСЛЕЖИВАНИЕ ПРИЛОЖЕНИЙ"
                        android:textColor="@color/on_surface"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/usageStatsStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Для смены разрешения только в приложениях"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/btnGrantUsageStats"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="ВКЛЮЧИТЬ ДОСТУП"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:layout_marginTop="12dp"
                android:background="@drawable/btn_accent_bg" />
        </LinearLayout>

        <!-- Start button -->
        <Button
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="ЗАПУСТИТЬ"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:textColor="#FFFFFFFF"
            android:fontFamily="sans-serif-medium"
            android:enabled="false"
            android:background="@drawable/btn_start_bg"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>
