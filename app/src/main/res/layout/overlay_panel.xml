<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlayRoot"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/overlay_bg"
    android:padding="0dp"
    android:elevation="8dp">

    <!-- Header (draggable) -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/overlay_header"
        android:paddingStart="12dp"
        android:paddingEnd="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/panel_title"
            android:textColor="@color/on_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnCollapse"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_collapse"
            android:contentDescription="@string/collapse"
            android:scaleType="centerInside" />
    </LinearLayout>

    <!-- Content -->
    <LinearLayout
        android:id="@+id/content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Native resolution info -->
        <TextView
            android:id="@+id/tvNativeRes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/on_surface_variant"
            android:textSize="11sp"
            android:layout_marginBottom="8dp" />

        <!-- Width -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/width_label"
            android:textColor="@color/on_surface"
            android:textSize="12sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <SeekBar
                android:id="@+id/seekWidth"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progressTint="@color/slider_thumb"
                android:thumbTint="@color/slider_thumb" />

            <EditText
                android:id="@+id/etWidth"
                android:layout_width="72dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="@color/surface_variant"
                android:textColor="@color/on_surface"
                android:textColorHint="@color/on_surface_variant"
                android:textSize="13sp"
                android:inputType="number"
                android:gravity="center"
                android:padding="4dp"
                android:hint="1080" />
        </LinearLayout>

        <!-- Height -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/height_label"
            android:textColor="@color/on_surface"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <SeekBar
                android:id="@+id/seekHeight"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progressTint="@color/slider_thumb"
                android:thumbTint="@color/slider_thumb" />

            <EditText
                android:id="@+id/etHeight"
                android:layout_width="72dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="@color/surface_variant"
                android:textColor="@color/on_surface"
                android:textColorHint="@color/on_surface_variant"
                android:textSize="13sp"
                android:inputType="number"
                android:gravity="center"
                android:padding="4dp"
                android:hint="2400" />
        </LinearLayout>

        <!-- Reset button -->
        <Button
            android:id="@+id/btnReset"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="@string/reset_button"
            android:textSize="13sp"
            android:layout_marginTop="12dp" />

        <!-- Presets -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/presets_title"
            android:textColor="@color/on_surface"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupPresets"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </HorizontalScrollView>

        <Button
            android:id="@+id/btnSavePreset"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:text="@string/save_preset"
            android:textSize="12sp"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</LinearLayout>
